# Vision Trader runtime profile
#
# Copy to .env.local and source it before running:
#   set -a && source .env.local && set +a

# HTTP dashboard/API port. Netty WebSocket currently starts on 9090.
JETTY_PORT=8080

# Clean-room HTTP benchmark switch. Keep false for normal trading behavior.
CLEAN_ROOM_ORDERS=false

# Journal options. Enable at most one.
USE_MAPPED_JOURNAL=false
MAPPED_JOURNAL_PATH=data/mapped-command-journal.dat
MAPPED_JOURNAL_MAX_RECORDS=1000000

USE_CHRONICLE_JOURNAL=false
CHRONICLE_JOURNAL_PATH=data/chronicle-command-journal
CHRONICLE_JOURNAL_RING_SIZE=65536

USE_DISK_JOURNAL=false

# Local active-passive replication channel for HA development tests.
USE_IN_MEMORY_REPLICATION=false
REPLICATION_CAPACITY=65536

# Optional external symbol/reference-price bootstrap.
# simulated = built-in symbols; polygon = REST snapshot bootstrap.
MARKET_DATA_PROVIDER=simulated
POLYGON_API_KEY=
MARKET_DATA_SYMBOLS=AAPL,GOOGL,MSFT,TSLA,AMZN

# k6 defaults
BASE_URL=http://localhost:8080
WS_URL=ws://localhost:9090/ws/orders
EXPECTED_STATUS=202
TARGET_VUS=500
TEST_DURATION=60s
K6_TRADER_CASH=100000000000000
